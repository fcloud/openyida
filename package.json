{
  "name": "openyida",
  "version": "1.0.0-beta.0",
  "description": "OpenYida CLI - 宜搭低代码 AI 开发工具（安装即用，零配置）",
  "bin": {
    "openyida": "./bin/yida.js",
    "yida": "./bin/yida.js"
  },
  "files": [
    "bin/",
    "lib/",
    "project/",
    "yida-skills/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint bin/ lib/ scripts/ --ext .js",
    "lint:fix": "eslint bin/ lib/ scripts/ --ext .js --fix",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": ["yida", "aliwork", "dingtalk", "cli", "openyida", "low-code", "ai", "qoder", "wukong"],
  "author": "OpenYida Contributors",
  "license": "MIT",
  "dependencies": {
    "@babel/standalone": "^7.15.1",
    "playwright": "^1.40.0",
    "uglify-js": "^3.19.3"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "jest": {
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ]
  },
  "engines": {
    "node": ">=16"
  }
}
