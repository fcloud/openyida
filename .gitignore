# See https://help.github.com/ignore-files/ for more about ignoring files.

# dependencies
node_modules/

# build output
dist/
*.tgz

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# lock files (npm only)
pnpm-lock.yaml
yarn.lock

# editors & IDEs
.idea/
.vscode/
*.swp
*.swo
*.dia~
.happypack

# OS
.DS_Store
Thumbs.db

# environment
.env
.env.local
.env.*.local

# coverage
coverage/

# AI 工具配置（保留 CLAUDE.md）
.qoder/*
.claude/*
!.claude/CLAUDE.md
# ── openyida 用户工作区 ────────────────────────────
# 根目录临时缓存（AI 生成的中间文件，不入库）
.cache/

# 登录态 & Schema 缓存（敏感信息，不入库）
openyida/.cache/*
!openyida/.cache/.gitkeep
!openyida/.cache/demo-*

# 登录态缓存（敏感信息，不入库）
.cache/
**/cookies.json

# 自定义页面编译产物
openyida/pages/dist/*
!openyida/pages/dist/.gitkeep

# 用户自定义页面源码（保留 demo 示例）
openyida/pages/src/*
!openyida/pages/src/demo-*

# 需求文档（保留 demo 示例）
openyida/prd/*
!openyida/prd/demo-*